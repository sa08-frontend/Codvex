# ── Codvex Backend Environment Variables ──
# Copy this file to .env and fill in your values

# Server
PORT=5000

# MongoDB (local or Atlas)
# Local:  mongodb://localhost:27017/codvex
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/codvex
MONGO_URI=mongodb://localhost:27017/codvex

# Gmail SMTP (use an App Password, not your main Gmail password)
# Enable 2FA → Google Account → Security → App Passwords
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Codvex team email (receives admin notifications)
CODVEX_EMAIL=team@codvex.in

# Codvex WhatsApp number — digits only, with country code, no spaces or +
# e.g. India +91 98765 43210 → 919876543210
CODVEX_WA=919876543210
